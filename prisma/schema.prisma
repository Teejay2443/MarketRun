generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  estate        String?
  role          String   @default("requester")
  rating        Float    @default(5.0)
  walletBalance Float    @default(0)
  totalEarned   Float    @default(0)

  // Monnify Reserved Account
  reservedAccountNumber String?
  reservedAccountBank   String?
  reservedAccountRef    String?

  // KYC
  kycStatus   String   @default("UNVERIFIED")
  kycBvn      String?
  kycVerifiedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  errandsAsRequester Errand[]       @relation("RequesterErrands")
  errandsAsShopper   Errand[]       @relation("ShopperErrands")
  messagesSent       Message[]      @relation("SentMessages")
  reviewsGiven       Review[]       @relation("GivenReviews")
  reviewsReceived    Review[]       @relation("ReceivedReviews")
  notifications      Notification[]
}

model Errand {
  id          String   @id @default(cuid())
  title       String
  description String
  market      String
  items       String
  budget      Float
  reward      Float
  status      String   @default("OPEN")
  address     String
  estate      String?
  requesterId String
  shopperId   String?
  monnifyRef  String?
  paymentRef  String?
  paymentStatus String?

  // Monnify Invoice
  invoiceId    String?
  invoiceUrl   String?
  invoiceRef   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  requester User    @relation("RequesterErrands", fields: [requesterId], references: [id])
  shopper   User?   @relation("ShopperErrands", fields: [shopperId], references: [id])

  transactions Transaction[]
  messages     Message[]
  review       Review?
}

model Transaction {
  id            String   @id @default(cuid())
  errandId      String
  amount        Float
  platformFee   Float
  shopperPayout Float
  monnifyRef    String?
  status        String   @default("PENDING")
  createdAt     DateTime @default(now())

  errand Errand @relation(fields: [errandId], references: [id])
}

model WebhookLog {
  id          String   @id @default(cuid())
  eventType   String
  payload     String
  signature   String?
  processed   Boolean  @default(false)
  idempotencyKey String? @unique
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entityType String
  entityId  String
  userId    String?
  details   String?
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  errandId  String
  senderId  String
  content   String
  createdAt DateTime @default(now())

  errand Errand @relation(fields: [errandId], references: [id])
  sender User   @relation("SentMessages", fields: [senderId], references: [id])
}

model Review {
  id         String   @id @default(cuid())
  errandId   String   @unique
  reviewerId String
  revieweeId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  errand   Errand @relation(fields: [errandId], references: [id])
  reviewer User   @relation("GivenReviews", fields: [reviewerId], references: [id])
  reviewee User   @relation("ReceivedReviews", fields: [revieweeId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  errandId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
